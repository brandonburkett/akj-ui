            <li>Kazumiken</li>
            <li>Uchikomi</li>
          </ol>
        </div>
        <div class="cs12">
          <hr class="dark" />
          <h3>Toho and Bangai</h3>
        </div>
        <div class="cs4">
          <h4>Toho Waza</h4>
          <ol class="ol-decimal">
            <li>Mae</li>
            <li>Zengogiri</li>
            <li>Kiriage</li>
            <li>Shihogiri</li>
            <li>Kissakigaeshi</li>
          </ol>
        </div>
        <div class="cs4">
          <h4>Toryu Bangai</h4>
          <ol class="ol-decimal">
            <li>Mae</li>
            <li>Aranami</li>
            <li>Kesaguruma</li>
            <li>Takiguruma</li>
            <li>Tatsumaki</li>
          </ol>
        </div>
        <div class="cs4">
          <h4>Bangai</h4>
          <ol class="ol-decimal">
            <li>Hayanami</li>
            <li>Raiden</li>
            <li>Jinrai</li>
          </ol>
        </div>
      </PanelContent>
    </PanelSection>

    <Quote
      content="Once you understand the long sword, you will know all shorter swords."
      author="Sekiguchi Komei sensei"
    />

    <Footer />
  </BelowFold>
</StandardLayout>
