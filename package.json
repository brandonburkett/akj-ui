{
  "name": "akj-ui",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">= 24"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "pretest:e2e": "playwright install chromium",
    "test:e2e": "playwright test",
    "coverage": "vitest run --coverage",
    "lint:style": "stylelint \"src/**/*.css\" --fix",
    "prettier:write": "prettier --write \"./src/**/*.{ts,astro,css}\"",
    "prettier:check": "prettier -l \"./src/**/*.{ts,astro,css}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "astro": "^7.0.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "husky": "^9.1.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.3.0",
    "prettier-plugin-astro": "^0.14.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ]
  },
  "lint-staged": {
    "*.{ts,astro}": [
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ]
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true,
    "sharp@0.34.5": true
  }
}
