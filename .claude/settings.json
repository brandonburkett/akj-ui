{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npx astro:*)",
      "Bash(npx playwright:*)",
      "Bash(npx vitest:*)",
      "Bash(npx prettier:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git mv:*)",
      "Bash(git log:*)",
      "Bash(aws s3 ls:*)",
      "Bash(aws sts get-caller-identity)",
      "Bash(aws s3api get-bucket-lifecycle-configuration:*)",
      "Bash(aws cloudfront list-distributions:*)"
    ]
  },
  "worktree": { "baseRef": "head" }
}
